<Window x:Class="BPO_ex4.LinkerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройка цифровой увязки" Height="320" Width="650" 
        WindowStartupLocation="CenterOwner" Background="#F3F3F3">

    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="Соединение портов (Патч-корд)" FontSize="18" FontWeight="Bold" Foreground="#333" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <Grid Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" Padding="15" CornerRadius="5" BorderBrush="#CCC" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="ОТКУДА (Источник):" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,10"/>
                        <ComboBox x:Name="CbStationA" DisplayMemberPath="StationName" Margin="0,0,0,15" Height="25"/>
                        <TextBlock Text="Порт выхода:" Margin="0,0,0,5"/>
                        <ComboBox x:Name="CbPortA" Height="25">
                            <ComboBoxItem Content="Порт 1 (UV_EX1)"/>
                            <ComboBoxItem Content="Порт 2 (UV_EX2)"/>
                            <ComboBoxItem Content="Порт 3 (UV_EX3)"/>
                            <ComboBoxItem Content="Порт 4 (UV_EX4)"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Column="1" Text=" 🡒 " FontSize="40" Foreground="#888" VerticalAlignment="Center" Margin="15,0"/>

                <Border Grid.Column="2" Background="White" Padding="15" CornerRadius="5" BorderBrush="#CCC" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="КУДА (Приемник):" FontWeight="Bold" Foreground="#28A745" Margin="0,0,0,10"/>
                        <ComboBox x:Name="CbStationB" DisplayMemberPath="StationName" Margin="0,0,0,15" Height="25"/>
                        <TextBlock Text="Порт входа:" Margin="0,0,0,5"/>
                        <ComboBox x:Name="CbPortB" Height="25">
                            <ComboBoxItem Content="Порт 1 (UV_EX1)"/>
                            <ComboBoxItem Content="Порт 2 (UV_EX2)"/>
                            <ComboBoxItem Content="Порт 3 (UV_EX3)"/>
                            <ComboBoxItem Content="Порт 4 (UV_EX4)"/>
                        </ComboBox>
                    </StackPanel>
                </Border>
            </Grid>

            <Button Content="🔗 СОЕДИНИТЬ СТАНЦИИ" Height="45" Background="#007ACC" Foreground="White" FontSize="14" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Click="Connect_Click"/>
        </StackPanel>
    </Grid>
</Window>