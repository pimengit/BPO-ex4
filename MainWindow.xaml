<Window x:Class="BPO_ex4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logic Studio - Мульти-станционная система" Height="800" Width="1300" WindowStartupLocation="CenterScreen">

    <Grid Background="#2D2D30">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="15,0" VerticalAlignment="Center">
            <Button Content="🔗 ЛИНКЕР" Click="OpenLinker_Click" Width="130" Height="34" Background="#007ACC" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,20,0"/>
            <Button Content="➕ НОВАЯ СТАНЦИЯ" Click="AddStation_Click" Width="160" Height="34" Background="#28A745" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>

        <TabControl Grid.Row="1" x:Name="StationsTabs" Background="#F3F3F3" BorderThickness="0">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="20,8"/>
                    <Setter Property="Background" Value="#3E3E42"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#F3F3F3"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.ItemContainerStyle>
        </TabControl>
    </Grid>
</Window>