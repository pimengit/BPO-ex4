<Window x:Class="BPO_ex4.EditNodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connection Editor" Height="250" Width="500" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Border Padding="15" Margin="0,0,0,6">
        <StackPanel >



            <GroupBox  Margin="0,0,0,15" Padding="5">
                <StackPanel>
                    <TextBlock Text="Тип переменной" Margin="0,5,0,2" Foreground="#555"/>
                    <ComboBox Name="CmbVariable" SelectionChanged="CmbVariable_SelectionChanged"/>

                    <TextBlock Text="Переменная" Margin="0,10,0,2" Foreground="#555"/>
                    <ComboBox Name="CmbIndex" IsEditable="True" StaysOpenOnEdit="True" IsTextSearchEnabled="True">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Index}" FontWeight="Bold" Width="40"/>
                                    <TextBlock Text="{Binding Description}" Foreground="Gray" FontStyle="Italic"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </GroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0" >
                <Button Content="Сохранить" Click="BtnSave_Click" Width="210"  Height="30" Margin="0,0,10,0"/>
                <Button Content="Отмена" IsCancel="True" Width="210"  Height="30" />
                
            </StackPanel>
        </StackPanel>
    </Border>
</Window>